---
const ADDRESS = "Архангельск, Дачная улица, 64 к1 ст7";
const EXACT_POINT = "40.692209,64.517304";
const MAP_CENTER = "40.696500,64.518800";
const MAP_ZOOM = "14.2";
const YANDEX_MAPS_EMBED_URL = `https://yandex.ru/map-widget/v1/?ll=${encodeURIComponent(MAP_CENTER)}&pt=${encodeURIComponent(`${EXACT_POINT},pm2rdm`)}&z=${MAP_ZOOM}`;
const YANDEX_MAPS_LINK = `https://yandex.ru/maps/?ll=${encodeURIComponent(MAP_CENTER)}&pt=${encodeURIComponent(EXACT_POINT)}&z=${MAP_ZOOM}`;
---
<section id="contacts" class="py-16 md:py-20 px-6 md:px-8 bg-white">
  <div class="max-w-[1440px] mx-auto">
    <h2
      class="text-[28px] leading-tight md:text-[40px] md:leading-tight font-bold mb-8 md:mb-12 text-center text-gray-900"
      style="font-family: 'Bitter', serif"
    >
      Контакты и логистика
    </h2>

    <div class="grid grid-cols-1 lg:grid-cols-[minmax(0,0.96fr)_minmax(0,1.04fr)] gap-5 md:gap-6 lg:gap-7">
      <div>
        <div class="bg-gray-50 rounded-lg p-6 md:p-8 mb-6">
          <h3
            class="text-xl md:text-2xl font-bold mb-4 md:mb-6 text-gray-900"
            style="font-family: 'Bitter', serif"
          >
            Лесстройснаб
          </h3>
          <div class="space-y-4">
            <div class="flex items-start gap-3 md:gap-4">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 md:w-6 md:h-6 text-green-600 flex-shrink-0 mt-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 4.993-5.539 10.193-7.399 11.799a1 1 0 0 1-1.202 0C9.539 20.193 4 14.993 4 10a8 8 0 0 1 16 0"/><circle cx="12" cy="10" r="3"/></svg>
              <div style="font-family: 'Inter', sans-serif">
                <p class="font-medium text-gray-900 text-base">Адрес производства:</p>
                <p class="text-sm md:text-base text-gray-600">{ADDRESS}</p>
              </div>
            </div>
            <div class="flex items-start gap-3 md:gap-4">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 md:w-6 md:h-6 text-green-600 flex-shrink-0 mt-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.61 3.4 2 2 0 0 1 3.6 1.22h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.8a16 16 0 0 0 6.29 6.29l.95-.95a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
              <div style="font-family: 'Inter', sans-serif">
                <p class="font-medium text-gray-900 text-base">Телефоны:</p>
                <p class="text-sm md:text-base text-gray-600">+7 (911) 551-20-15</p>
                <p class="text-sm md:text-base text-gray-600">+7 (960) 012-50-53</p>
                <p class="text-sm md:text-base text-gray-600">+7 (8182) 40-30-04</p>
              </div>
            </div>
            <div class="flex items-start gap-3 md:gap-4">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 md:w-6 md:h-6 text-green-600 flex-shrink-0 mt-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
              <div style="font-family: 'Inter', sans-serif">
                <p class="font-medium text-gray-900 text-base">Часы работы:</p>
                <p class="text-sm md:text-base text-gray-600">Пн-Пт: 9:00 – 18:00</p>
                <p class="text-sm md:text-base text-gray-600">Сб-Вс: выходной</p>
              </div>
            </div>
          </div>
        </div>

        <div class="bg-green-50 rounded-lg p-6 md:p-8 border border-green-200">
          <div class="flex items-center gap-3 mb-4">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 md:w-6 md:h-6 text-green-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="3 11 22 2 13 21 11 13 3 11"/></svg>
            <h4 class="text-lg md:text-xl font-bold text-gray-900" style="font-family: 'Bitter', serif">Как проехать</h4>
          </div>
          <div class="space-y-2 text-sm md:text-base text-gray-700 leading-relaxed" style="font-family: 'Inter', sans-serif">
            <p>1. Постройте маршрут до адреса: Архангельск, Дачная улица, 64 к1 ст7</p>
            <p>2. Ориентир на месте: территория складов и производственных строений</p>
            <p>3. Для точного подъезда удобнее открыть маршрут в Яндекс Картах по кнопке справа</p>
            <p class="font-medium mt-4">На территории есть бесплатная парковка для грузового транспорта</p>
          </div>
        </div>
      </div>

      <div class="bg-gray-200 rounded-lg overflow-hidden shadow-lg h-[400px] md:h-[500px] lg:h-full lg:min-h-[400px]">
        <div class="w-full h-full flex items-center justify-center relative">
          <iframe
            title={`Карта: ${ADDRESS}`}
            src={YANDEX_MAPS_EMBED_URL}
            class="w-full h-full border-0"
            loading="lazy"
            allowfullscreen
          />
          <div class="absolute inset-0 pointer-events-none bg-gradient-to-t from-black/10 to-transparent" />
          <a
            href={YANDEX_MAPS_LINK}
            target="_blank"
            rel="noreferrer"
            class="absolute right-4 top-4 rounded-full bg-white/95 px-4 py-2 text-sm font-medium text-gray-900 shadow-md transition hover:bg-white"
            style="font-family: 'Inter', sans-serif"
          >
            Открыть в Яндекс Картах
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
