---
import ClockIcon from "../assets/icons/Clock.svg";
import MapPinIcon from "../assets/icons/MapPin.svg";
import NavigationArrowIcon from "../assets/icons/NavigationArrow.svg";
import PhoneCallIcon from "../assets/icons/PhoneCall.svg";

const ADDRESS = "Архангельск, Дачная улица, 64 к1 ст7";
const ADDRESS2 = "Архангельская обл., Приморский МО, д. Часовенское, 19 стр. 1";
const POINT1 = "40.692209,64.517304";
const POINT2 = "40.643395,64.463871";
const MAP_CENTER = "40.668000,64.490000";
const MAP_ZOOM = "12";
const pts = encodeURIComponent(`${POINT1},pm2rdm~${POINT2},pm2rdm`);
const YANDEX_MAPS_EMBED_URL = `https://yandex.ru/map-widget/v1/?ll=${encodeURIComponent(MAP_CENTER)}&pt=${pts}&z=${MAP_ZOOM}`;
const YANDEX_MAPS_LINK = `https://yandex.ru/maps/?ll=${encodeURIComponent(MAP_CENTER)}&pt=${pts}&z=${MAP_ZOOM}`;
---
<section id="contacts" class="py-16 md:py-20 px-6 md:px-8 bg-white">
  <div class="max-w-[1440px] mx-auto">
    <h2
      class="text-[28px] leading-tight md:text-[40px] md:leading-tight font-bold mb-8 md:mb-12 text-center text-gray-900"
      style="font-family: 'Bitter', serif"
    >
      Контакты и логистика
    </h2>

    <div class="grid grid-cols-1 lg:grid-cols-[minmax(0,0.96fr)_minmax(0,1.04fr)] gap-5 md:gap-6 lg:gap-7">
      <div>
        <div class="bg-gray-50 rounded-lg p-6 md:p-8 mb-6">
          <h3
            class="text-xl md:text-2xl font-bold mb-4 md:mb-6 text-gray-900"
            style="font-family: 'Bitter', serif"
          >
            Лесстройснаб
          </h3>
          <div class="space-y-4">
            <div class="flex items-start gap-3 md:gap-4">
              <MapPinIcon class="w-5 h-5 md:w-6 md:h-6 text-green-600 shrink-0 mt-1" aria-hidden="true" />
              <div style="font-family: 'Inter', sans-serif">
                <p class="font-medium text-gray-900 text-base">Адрес производства:</p>
                <p class="text-sm md:text-base text-gray-600">{ADDRESS} <span class="text-green-600 font-medium">(основной)</span></p>
                <p class="text-sm md:text-base text-gray-600 mt-1">{ADDRESS2}</p>
              </div>
            </div>
            <div class="flex items-start gap-3 md:gap-4">
              <PhoneCallIcon class="w-5 h-5 md:w-6 md:h-6 text-green-600 shrink-0 mt-1" aria-hidden="true" />
              <div style="font-family: 'Inter', sans-serif">
                <p class="font-medium text-gray-900 text-base">Телефоны:</p>
                <p class="text-sm md:text-base text-gray-600">+7 (911) 551-20-15</p>
                <p class="text-sm md:text-base text-gray-600">+7 (960) 012-50-53</p>
                <p class="text-sm md:text-base text-gray-600">+7 (8182) 40-30-04</p>
              </div>
            </div>
            <div class="flex items-start gap-3 md:gap-4">
              <ClockIcon class="w-5 h-5 md:w-6 md:h-6 text-green-600 shrink-0 mt-1" aria-hidden="true" />
              <div style="font-family: 'Inter', sans-serif">
                <p class="font-medium text-gray-900 text-base">Часы работы:</p>
                <p class="text-sm md:text-base text-gray-600">Пн-Пт: 8:00 – 18:00</p>
                <p class="text-sm md:text-base text-gray-600">Сб: 8:00 – 16:00</p>
                <p class="text-sm md:text-base text-gray-600">Вс: выходной</p>
              </div>
            </div>
          </div>
        </div>

        <div class="bg-green-50 rounded-lg p-6 md:p-8 border border-green-200">
          <div class="flex items-center gap-3 mb-4">
            <NavigationArrowIcon class="w-6 h-6 md:w-7 md:h-7 text-green-600" aria-hidden="true" />
            <h4 class="text-lg md:text-xl font-bold text-gray-900" style="font-family: 'Bitter', serif">Как проехать</h4>
          </div>
          <div class="space-y-2 text-sm md:text-base text-gray-700 leading-relaxed" style="font-family: 'Inter', sans-serif">
            <p>1. Постройте маршрут до адреса: Архангельск, Дачная улица, 64 к1 ст7</p>
            <p>2. Ориентир на месте: территория складов и производственных строений</p>
            <p>3. Для точного подъезда удобнее открыть маршрут в Яндекс Картах по кнопке справа</p>
            <p class="font-medium mt-4">На территории есть бесплатная парковка для грузового транспорта</p>
          </div>
        </div>
      </div>

      <div class="bg-gray-200 rounded-lg overflow-hidden shadow-lg h-[400px] md:h-[500px] lg:h-full lg:min-h-[400px]">
        <div class="w-full h-full flex items-center justify-center relative">
          <iframe
            title={`Карта: ${ADDRESS}`}
            src={YANDEX_MAPS_EMBED_URL}
            class="w-full h-full border-0"
            loading="lazy"
            allowfullscreen
          />
          <div class="absolute inset-0 pointer-events-none bg-linear-to-t from-black/10 to-transparent" />
          <a
            href={YANDEX_MAPS_LINK}
            target="_blank"
            rel="noreferrer"
            class="absolute right-4 top-4 rounded-full bg-white/95 px-4 py-2 text-sm font-medium text-gray-900 shadow-md transition hover:bg-white"
            style="font-family: 'Inter', sans-serif"
          >
            Открыть в Яндекс Картах
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
