---
import { Image } from "astro:assets";
import photo2 from "../assets/gallery/2.jpg";
import photo3 from "../assets/gallery/3.jpg";
import photo4 from "../assets/gallery/4.jpg";
import photo6 from "../assets/gallery/6.jpg";
import photo7 from "../assets/gallery/7.webp";
import photo9 from "../assets/gallery/9.webp";
import photo10 from "../assets/gallery/10.webp";

const photos = [
  { src: photo10, alt: "Въезд на производственную базу", gridClass: "md:col-span-2 md:row-span-2" },
  { src: photo3, alt: "Погрузка кругляка манипулятором", gridClass: "" },
  { src: photo4, alt: "Отгрузка пиломатериалов краном", gridClass: "md:row-span-2" },
  { src: photo7, alt: "Склад пиломатериалов под открытым небом", gridClass: "" },
  { src: photo6, alt: "Загрузка пиломатериалов на площадке", gridClass: "" },
  { src: photo2, alt: "Длинномер с готовыми пиломатериалами", gridClass: "md:col-span-2" },
  { src: photo9, alt: "Штабеля готового бруса на складе", gridClass: "" },
];
---
<section id="gallery" class="py-16 md:py-20 px-6 md:px-8 bg-white">
  <div class="max-w-[1440px] mx-auto">
    <h2
      class="text-[28px] leading-tight md:text-[40px] md:leading-tight font-bold mb-3 md:mb-4 text-center text-gray-900"
      style="font-family: 'Bitter', serif"
    >
      Наше производство и склад
    </h2>
    <p
      class="text-center text-gray-600 mb-8 md:mb-12 text-lg md:text-xl"
      style="font-family: 'Inter', sans-serif"
    >
      Собственное производство в Архангельске — контроль качества на каждом этапе
    </p>

    <div class="grid grid-cols-1 md:grid-cols-4 md:auto-rows-[240px] gap-4 md:gap-6">
      {photos.map((photo) => (
        <div class={`relative group overflow-hidden rounded-xl bg-gray-100 shadow-md hover:shadow-2xl transition-all duration-500 ${photo.gridClass}`}>
          <Image
            src={photo.src}
            alt={photo.alt}
            class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700 ease-out"
            loading="lazy"
            quality={86}
          />
          <div class="absolute inset-0 bg-linear-to-t from-black/60 via-black/0 to-black/0 opacity-0 group-hover:opacity-100 transition-opacity duration-500">
            <div class="absolute bottom-0 left-0 right-0 p-4 md:p-6 translate-y-2 group-hover:translate-y-0 transition-transform duration-500">
              <p class="text-white font-medium text-base md:text-lg" style="font-family: 'Inter', sans-serif">
                {photo.alt}
              </p>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
