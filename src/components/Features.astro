---
const features = [
  {
    title: "Честный объём",
    description: "Точные измерения и полное соответствие заявленным параметрам",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7 md:w-8 md:h-8 text-green-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21.3 15.3a2.4 2.4 0 0 1 0 3.4l-2.6 2.6a2.4 2.4 0 0 1-3.4 0L2.7 8.7a2.41 2.41 0 0 1 0-3.4l2.6-2.6a2.41 2.41 0 0 1 3.4 0Z"/><path d="m14.5 12.5 2-2"/><path d="m11.5 9.5 2-2"/><path d="m8.5 6.5 2-2"/><path d="m17.5 15.5 2-2"/></svg>`,
  },
  {
    title: "Прямые поставки",
    description: "Работаем напрямую с производства — без посредников",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7 md:w-8 md:h-8 text-green-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 8c0 4.5-7 12-7 12S3 12.5 3 8a7 7 0 0 1 14 0Z"/><circle cx="10" cy="8" r="2"/><path d="M22 8c0 4.5-7 12-7 12"/><path d="M22 8a7 7 0 0 0-7-7"/></svg>`,
  },
  {
    title: "Гарантия качества",
    description: "Камерная сушка и контроль на каждом этапе производства",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7 md:w-8 md:h-8 text-green-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22a7 7 0 0 0 7-7c0-2-1-3.9-3-5.5s-3.5-4-4-6.5c-.5 2.5-2 4.9-4 6.5C6 11.1 5 13 5 15a7 7 0 0 0 7 7z"/></svg>`,
  },
  {
    title: "Северный лес",
    description: "Архангельская древесина с уникальными характеристиками",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7 md:w-8 md:h-8 text-green-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 4.993-5.539 10.193-7.399 11.799a1 1 0 0 1-1.202 0C9.539 20.193 4 14.993 4 10a8 8 0 0 1 16 0"/><circle cx="12" cy="10" r="3"/></svg>`,
  },
];
---
<section class="py-12 md:py-16 px-6 md:px-8 bg-white border-b border-gray-200">
  <div class="max-w-[1440px] mx-auto">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 md:gap-8">
      {features.map((feature) => (
        <div class="text-center">
          <div class="inline-flex items-center justify-center w-14 h-14 md:w-16 md:h-16 bg-green-100 rounded-full mb-3 md:mb-4">
            <Fragment set:html={feature.icon} />
          </div>
          <h3
            class="text-lg md:text-xl font-bold mb-2 text-gray-900"
            style="font-family: 'Bitter', serif"
          >
            {feature.title}
          </h3>
          <p
            class="text-sm md:text-base text-gray-600"
            style="font-family: 'Inter', sans-serif"
          >
            {feature.description}
          </p>
        </div>
      ))}
    </div>
  </div>
</section>
