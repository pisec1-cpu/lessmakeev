---
import CheckCircleIcon from "../assets/icons/CheckCircle.svg";
import ClockCountdownIcon from "../assets/icons/ClockCountdown.svg";
import FilesIcon from "../assets/icons/Files.svg";
import TruckTrailerIcon from "../assets/icons/TruckTrailer.svg";

const features = [
  {
    title: "Соответствие ГОСТ",
    description: "Работаем по ГОСТ 8486-86 и 26002-83",
    Icon: CheckCircleIcon,
  },
  {
    title: "Отгрузка без задержек",
    description: "Со склада без ожидания производства",
    Icon: ClockCountdownIcon,
  },
  {
    title: "Работаем по ЭДО",
    description: "Документы в день отгрузки для ИП и юрлиц",
    Icon: FilesIcon,
  },
  {
    title: "Доставка под задачу",
    description: "Газель или КАМАЗ с манипулятором",
    Icon: TruckTrailerIcon,
  },
];
---
<section class="py-12 md:py-16 px-6 md:px-8 bg-white border-b border-gray-200">
  <div class="max-w-[1440px] mx-auto">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 md:gap-8">
      {features.map((feature) => {
        const Icon = feature.Icon;

        return (
        <div class="text-center">
          <div class="inline-flex items-center justify-center w-14 h-14 md:w-16 md:h-16 bg-green-100 rounded-full mb-3 md:mb-4">
            <Icon class="w-7 h-7 md:w-8 md:h-8 text-green-600" aria-hidden="true" />
          </div>
          <h3
            class="text-lg md:text-xl font-bold mb-2 text-gray-900"
            style="font-family: 'Bitter', serif"
          >
            {feature.title}
          </h3>
          <p
            class="text-sm md:text-base text-gray-600"
            style="font-family: 'Inter', sans-serif"
          >
            {feature.description}
          </p>
        </div>
        );
      })}
    </div>
  </div>
</section>
