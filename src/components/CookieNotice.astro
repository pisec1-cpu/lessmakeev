---
import CookieIcon from "../assets/icons/Cookie.svg";
---
<div
  id="cookie-notice"
  class="fixed inset-x-4 bottom-4 z-50 hidden sm:inset-x-auto sm:left-4 sm:max-w-[380px]"
  aria-live="polite"
>
  <div class="rounded-2xl border border-gray-200/80 bg-white/95 p-5 shadow-[0_18px_45px_rgba(15,23,42,0.14)] backdrop-blur-sm">
    <p class="flex items-center gap-3 text-lg font-semibold text-gray-800" style="font-family: 'Bitter', serif">
      <CookieIcon class="h-7 w-7 shrink-0 text-green-600" aria-hidden="true" />
      Использование cookie
    </p>
    <p class="mt-3 text-sm leading-6 text-gray-600" style="font-family: 'Inter', sans-serif">
      Мы используем cookie, чтобы сайт работал корректно и чтобы понимать, как им пользуются посетители.
    </p>
    <div class="mt-5 flex items-center justify-between gap-4">
      <a
        href="/cookie.pdf"
        target="_blank"
        rel="nofollow noreferrer"
        class="text-sm leading-none text-gray-700 underline decoration-gray-400 underline-offset-4 transition-colors hover:text-green-700"
        style="font-family: 'Inter', sans-serif"
      >
        Правила использования cookie
      </a>
      <button
        id="cookie-notice-accept"
        type="button"
        class="shrink-0 rounded-lg border-2 border-gray-900 px-5 py-3 text-sm font-medium text-gray-900 transition-colors hover:bg-gray-900 hover:text-white focus:outline-none focus:ring-2 focus:ring-gray-900 focus:ring-offset-2"
        style="font-family: 'Inter', sans-serif"
      >
        Хорошо
      </button>
    </div>
  </div>
</div>

<script>
  const COOKIE_NOTICE_KEY = "cookie-consent";
  const cookieNotice = document.getElementById("cookie-notice");
  const cookieAcceptButton = document.getElementById("cookie-notice-accept");

  function hideCookieNotice() {
    cookieNotice?.classList.add("hidden");
  }

  function showCookieNotice() {
    cookieNotice?.classList.remove("hidden");
  }

  let hasConsent = false;

  try {
    hasConsent = window.localStorage.getItem(COOKIE_NOTICE_KEY) === "accepted";
  } catch {
    hasConsent = false;
  }

  if (!hasConsent) {
    showCookieNotice();
  }

  cookieAcceptButton?.addEventListener("click", () => {
    try {
      window.localStorage.setItem(COOKIE_NOTICE_KEY, "accepted");
    } catch {
      // Keep the notice dismissible even if storage is unavailable.
    }

    hideCookieNotice();
  });
</script>
