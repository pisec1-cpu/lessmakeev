---
import { Image } from 'astro:assets';
import roundTimber from '../assets/catalog/round_timber.jpg';
import gorbyl from '../assets/catalog/горбыль на дрова.jpg';
import lafet from '../assets/catalog/лафает (брус 2х кантный).jpg';
import brus from '../assets/catalog/брус 100-200.jpg';
import brusok from '../assets/catalog/брусок 50-50.jpg';
import doska from '../assets/catalog/доска обрезная 25-150.jpg';
import ArrowRightIcon from '../assets/icons/ArrowRight.svg';
import FilePdfIcon from '../assets/icons/FilePdf.svg';

const catalogItems = [
  { id: 1, name: "Брус", image: brus, price: "12 000", description: "Для стоек, опор, несущих стен, домов, бань и капитальных построек.", featured: false },
  { id: 2, name: "Доска обрезная", image: doska, price: "18 000", description: "Для обрешётки, настилов, каркасов, перекрытий и стропил.", featured: true },
  { id: 3, name: "Брусок", image: brusok, price: "20 000", description: "Для обрешётки, реек, перегородок и отделочных работ.", featured: false },
  { id: 4, name: "Брус 2-х кантный", image: lafet, price: "13 000", description: "Подходит для строительства домов, бань и хозяйственных построек.", featured: false },
  { id: 5, name: "Лес кругляк", image: roundTimber, price: "12 000", description: "Сосна и ель архангельской заготовки. Прямые поставки с производства.", featured: false },
  { id: 6, name: "Дрова горбыль", image: gorbyl, price: "12 000", description: "Горбыль для отопления. Продажа машинами по 12 м³.", featured: false },
];
---
<section id="catalog" class="relative py-16 md:py-20 px-6 md:px-8 bg-white overflow-hidden">
  <div class="max-w-[1440px] mx-auto relative">
    <h2
      class="text-[28px] leading-tight md:text-[40px] md:leading-tight font-bold mb-3 md:mb-4 text-center text-gray-900"
      style="font-family: 'Bitter', serif"
    >
      Каталог продукции
    </h2>
    <p
      class="text-center text-gray-600 mb-8 md:mb-12 text-lg md:text-xl"
      style="font-family: 'Inter', sans-serif"
    >
      Самые популярные материалы и размеры для заказа
    </p>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 md:gap-8 mb-10 md:mb-12">
      {catalogItems.map((item) => (
        <div class={`group bg-white border-2 rounded-lg overflow-hidden hover:shadow-xl transition-shadow duration-300 flex flex-col relative ${item.featured ? 'border-green-600 shadow-md shadow-green-200' : 'border-gray-200'}`}>
          {item.featured && (
            <div class="absolute top-3 left-3 z-10 flex items-center gap-1 px-2.5 py-1 bg-green-600 text-white text-xs font-semibold rounded-full shadow" style="font-family: 'Inter', sans-serif">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
              Популярный товар
            </div>
          )}
          <div class="aspect-5/3 overflow-hidden bg-gray-100">
            <Image src={item.image} alt={item.name} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" width={400} height={240} quality={85} />
          </div>
          <div class="p-5 md:p-6 flex flex-col flex-1">
            <div class="mb-3 flex items-baseline justify-between gap-2">
              <h3
                class="text-xl md:text-2xl font-bold text-gray-900"
                style="font-family: 'Bitter', serif"
              >
                {item.name}
              </h3>
              <p
                class="text-gray-900 text-lg md:text-xl font-bold whitespace-nowrap"
                style="font-family: 'Inter', sans-serif"
              >
                <span class="text-gray-500 font-normal text-base">от </span>{item.price} ₽/м³
              </p>
            </div>
            <p
              class="text-sm md:text-base text-gray-600 mb-4 flex-1 leading-relaxed"
              style="font-family: 'Inter', sans-serif"
            >
              {item.description}
            </p>
            <a
              href="#contacts"
              data-order-btn
              data-product={item.name}
              class="inline-flex items-center justify-center gap-2 w-full px-4 py-2.5 bg-green-700 text-white rounded-lg hover:bg-green-800 transition-colors text-base font-medium cursor-pointer"
              style="font-family: 'Inter', sans-serif"
            >
              Заказать
              <ArrowRightIcon class="w-4 h-4" aria-hidden="true" />
            </a>
          </div>
        </div>
      ))}
    </div>

    <div class="text-center">
      <a
        href="/price.pdf"
        target="_blank"
        rel="noreferrer"
        class="inline-flex items-center justify-center gap-2 px-6 md:px-8 py-3 md:py-4 border-2 border-gray-900 text-gray-900 rounded-lg hover:bg-gray-900 hover:text-white transition-colors text-sm md:text-base font-medium w-full sm:w-auto"
        style="font-family: 'Inter', sans-serif"
      >
        <FilePdfIcon class="w-5 h-5 md:w-6 md:h-6" aria-hidden="true" />
        Посмотреть весь прайс
      </a>
    </div>
  </div>
</section>
