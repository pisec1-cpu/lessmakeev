---
import { Image } from "astro:assets";
import heroImage from "../assets/hero/hero.jpg";
import ArrowRightIcon from "../assets/icons/ArrowRight.svg";
import HeroWave from "./HeroWave.astro";
---
<section id="hero" class="relative pt-32 md:pt-44 pb-36 md:pb-44 px-6 md:px-8 bg-gray-50 overflow-hidden">
  <Image
    src={heroImage}
    alt=""
    aria-hidden="true"
    class="absolute inset-0 h-full w-full object-cover"
    width={1400}
    height={671}
    quality={88}
    loading="eager"
  />
  <div class="absolute inset-0 bg-white/24"></div>
  <div class="absolute inset-0 bg-linear-to-b from-white/18 via-white/6 to-white/48"></div>
  <div class="relative z-20 max-w-[1440px] mx-auto">
    <div class="max-w-5xl mx-auto text-center">
      <h1
        class="text-3xl sm:text-4xl md:text-[52px] md:leading-[1.1] leading-tight font-bold mb-4 md:mb-6 text-gray-950"
        style="font-family: 'Bitter', serif"
      >
        Пиломатериалы от производителя<br />в&nbsp;Архангельске
      </h1>
      <div class="max-w-3xl mx-auto">
        <p
          class="text-base md:text-xl text-gray-800 font-medium mb-6 md:mb-8 leading-relaxed"
          style="font-family: 'Inter', sans-serif"
        >
          Прямые поставки без посредников. Любые размеры под заказ.
        </p>
      </div>
      <div class="flex justify-center">
        <a
          href="#catalog"
          class="inline-flex items-center justify-center gap-2 px-6 md:px-8 py-3 md:py-4 bg-green-700 text-white rounded-lg hover:bg-green-800 transition-colors text-sm md:text-base font-medium"
          style="font-family: 'Inter', sans-serif"
        >
          Перейти в каталог
          <ArrowRightIcon class="w-4 h-4 md:w-5 md:h-5" aria-hidden="true" />
        </a>
      </div>
    </div>
  </div>
  <HeroWave />
</section>
